#!/bin/bash
# whatsapp — Start WhatsApp Web client locally
# Access at: http://localhost:3030 (via SSH port forwarding)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

LOGDIR="$HOME/.openclaw/logs"
mkdir -p "$LOGDIR"

echo ""
echo -e "${CYAN}╔══════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     ${BOLD}WhatsApp Web Client${NC}${CYAN}               ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════╝${NC}"
echo ""

cd /workspaces/codespaces/whatsapp-web.js

# ─── Check if already running ─────────────────────────────────
PID=$(pgrep -f "node server.js" 2>/dev/null | head -1)
if [ -n "$PID" ] && ss -tlnp 2>/dev/null | grep -q ":3030 "; then
    echo -e "  ${GREEN}✓${NC} WhatsApp already running (PID $PID)"
else
    # Kill stale process if port is taken
    if ss -tlnp 2>/dev/null | grep -q ":3030 "; then
        echo -e "  ${YELLOW}→${NC} Port 3030 in use — cleaning up..."
        pkill -f "node server.js" 2>/dev/null || true
        sleep 1
    fi

    echo -e "  ${YELLOW}→${NC} Starting WhatsApp Web server on port 3030..."
    PORT=3030 nohup node server.js > "$LOGDIR/whatsapp.log" 2>&1 &
    
    # Wait for it to be ready
    for i in $(seq 1 15); do
        if ss -tlnp 2>/dev/null | grep -q ":3030 "; then
            break
        fi
        sleep 1
    done
    
    if ss -tlnp 2>/dev/null | grep -q ":3030 "; then
        PID=$(pgrep -f "node server.js" 2>/dev/null | head -1)
        echo -e "  ${GREEN}✓${NC} Started (PID $PID)"
    else
        echo -e "  ${RED}✗${NC} Failed to start — check logs"
        cat "$LOGDIR/whatsapp.log" | tail -5
    fi
fi

echo ""

# ─── Status ────────────────────────────────────────────────────
if ss -tlnp 2>/dev/null | grep -q ":3030 "; then
    QR_READY=$(curl -sf http://localhost:3030/api/status 2>/dev/null | grep -o '"hasQr":true' || echo "")
    READY=$(curl -sf http://localhost:3030/api/status 2>/dev/null | grep -o '"ready":true' || echo "")
    
    echo -e "  ${BOLD}URL:${NC}        ${CYAN}http://localhost:3030${NC}"
    echo ""
    
    if [ -n "$READY" ]; then
        echo -e "  ${GREEN}✅ Connected to WhatsApp${NC}"
    elif [ -n "$QR_READY" ]; then
        echo -e "  ${YELLOW}📱 QR code ready — open the URL and scan with your phone${NC}"
    else
        echo -e "  ${YELLOW}⏳ Initializing... refresh the page in a few seconds${NC}"
    fi
    
    echo ""
    echo -e "  ${BOLD}Logs:${NC}       ${CYAN}tail -f $LOGDIR/whatsapp.log${NC}"
    echo -e "  ${BOLD}Stop:${NC}        pkill -f \"node server.js\""
else
    echo -e "  ${RED}✗ WhatsApp is not running${NC}"
fi

echo ""