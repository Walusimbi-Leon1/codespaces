#!/bin/bash
# stop-openclaw — Stop 9router + OpenClaw gateway + cloudflared cleanly

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}╔══════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     ${BOLD}OpenClaw Stack Stopper${NC}${CYAN}          ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════╝${NC}"
echo ""

# Stop 9router's tunnel first (cloudflared)
CF_PID=$(pgrep -f 'cloudflared' 2>/dev/null | head -1)
if [ -n "$CF_PID" ]; then
  echo -e "  ${YELLOW}→${NC} Stopping cloudflared (PID $CF_PID)..."
  kill "$CF_PID" 2>/dev/null && echo -e "  ${GREEN}✓${NC} cloudflared stopped" || echo -e "  ${RED}✗${NC} Failed to stop cloudflared"
  sleep 1
fi

# Stop 9router
R9_PID=$(pgrep -f 'node.*9router' 2>/dev/null | head -1)
if [ -n "$R9_PID" ]; then
  echo -e "  ${YELLOW}→${NC} Stopping 9router (PID $R9_PID)..."
  kill "$R9_PID" 2>/dev/null && echo -e "  ${GREEN}✓${NC} 9router stopped" || echo -e "  ${RED}✗${NC} Failed to stop 9router"
  sleep 1
fi

# Stop OpenClaw gateway
OC_PID=$(pgrep -x openclaw 2>/dev/null | head -1)
if [ -n "$OC_PID" ]; then
  echo -e "  ${YELLOW}→${NC} Stopping OpenClaw gateway (PID $OC_PID)..."
  openclaw gateway stop 2>/dev/null || kill "$OC_PID" 2>/dev/null
  sleep 2
  
  # Check if it's still alive, force kill if needed
  OC_PID=$(pgrep -x openclaw 2>/dev/null | head -1)
  if [ -n "$OC_PID" ]; then
    echo -e "  ${YELLOW}→${NC} Force killing OpenClaw (PID $OC_PID)..."
    kill -9 "$OC_PID" 2>/dev/null
    echo -e "  ${GREEN}✓${NC} OpenClaw force killed"
  else
    echo -e "  ${GREEN}✓${NC} OpenClaw gateway stopped"
  fi
fi

echo ""

# Final status
if pgrep -f 'node.*9router\|openclaw\|cloudflared' >/dev/null 2>&1; then
  echo -e "${YELLOW}⚠  Some processes still running:${NC}"
  pgrep -a -f 'node.*9router\|openclaw\|cloudflared' 2>/dev/null | grep -v grep
else
  echo -e "${GREEN}✓ All services stopped.${NC}"
fi
echo ""
