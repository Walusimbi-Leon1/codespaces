#!/bin/bash
# run-openclaw — Start 9router + OpenClaw gateway with one command

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

LOGDIR="$HOME/.openclaw/logs"
mkdir -p "$LOGDIR"

# ─── helpers ────────────────────────────────────────────────────────────────
is_listening() {
  ss -tlnp 2>/dev/null | grep -q ":$1 "
}

get_9r_token() {
  node -e "
    const c=require('crypto'),f=require('fs'),o=require('os');
    const r=f.readFileSync(o.homedir()+'/.9router/machine-id','utf8').trim();
    const s=f.readFileSync(o.homedir()+'/.9router/auth/cli-secret','utf8').trim();
    console.log(c.createHash('sha256').update(r+'9r-cli-auth'+s).digest('hex').substring(0,16));
  " 2>/dev/null
}

fetch_9r_api() {
  local path="$1"
  local token
  token=$(get_9r_token)
  [ -z "$token" ] && return 1
  curl -sf -H "x-9r-cli-token: $token" "http://127.0.0.1:20128${path}" 2>/dev/null
}

service_pid() {
  local name="$1"
  case "$name" in
    9router)   pgrep -f 'node.*9router' 2>/dev/null | head -1 ;;
    openclaw)  pgrep -x openclaw 2>/dev/null | head -1 ;;
    cloudflared) pgrep -f 'cloudflared' 2>/dev/null | head -1 ;;
  esac
}

# ─── header ─────────────────────────────────────────────────────────────────
echo ""
echo -e "${CYAN}╔══════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     ${BOLD}OpenClaw Stack Launcher${NC}${CYAN}        ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════╝${NC}"
echo ""

# ─── 1. 9router ────────────────────────────────────────────────────────────
echo -e "${BOLD}1. 9router${NC}"

PID=$(service_pid 9router)
if [ -n "$PID" ]; then
  echo -e "  ${GREEN}✓${NC} Process already running (PID $PID)"
else
  echo -e "  ${YELLOW}→${NC} Starting 9router on port 20128..."
  # --tray runs in background (no interactive menu); --skip-update avoids network call
  nohup 9router --tray --skip-update > "$LOGDIR/9router.log" 2>&1 &
  sleep 3
  PID=$(service_pid 9router)
  if [ -n "$PID" ]; then
    echo -e "  ${GREEN}✓${NC} Started (PID $PID)"
  else
    echo -e "  ${RED}✗${NC} Failed to start 9router (check logs)"
  fi
fi

# Wait for it to listen
for i in $(seq 1 10); do
  is_listening 20128 && break
  sleep 1
done
if is_listening 20128; then
  echo -e "  ${GREEN}✓${NC} 9router ready on port 20128"
else
  echo -e "  ${RED}✗${NC} 9router not listening on port 20128"
fi

# ─── 2. 9router tunnel (cloudflared) ──────────────────────────────────────
echo ""
echo -e "${BOLD}2. Tunnel${NC}"

if is_listening 20128; then
  TUNNEL_DATA=$(fetch_9r_api /api/tunnel/status 2>/dev/null || echo "")
  RUNNING=$(echo "$TUNNEL_DATA" | grep -o '"running":true' 2>/dev/null)
  TUNNEL_URL=$(echo "$TUNNEL_DATA" | grep -o '"publicUrl":"[^"]*"' | cut -d'"' -f4 2>/dev/null)

  if [ -n "$RUNNING" ] && [ -n "$TUNNEL_URL" ]; then
    echo -e "  ${GREEN}✓${NC} Tunnel active → ${CYAN}$TUNNEL_URL${NC}"
  else
    # Try to enable it
    echo -e "  ${YELLOW}→${NC} Enabling tunnel..."
    ENABLE_DATA=$(fetch_9r_api /api/tunnel/enable -X POST 2>/dev/null || echo "")
    ENABLED_URL=$(echo "$ENABLE_DATA" | grep -o '"tunnelUrl":"[^"]*"' | cut -d'"' -f4 2>/dev/null)
    if [ -n "$ENABLED_URL" ]; then
      echo -e "  ${GREEN}✓${NC} Tunnel enabled → ${CYAN}${ENABLED_URL}${NC}"
    else
      echo -e "  ${YELLOW}  →${NC} Tunnel not yet available (9router will auto-start cloudflared)"
    fi
  fi
fi

# ─── 3. OpenClaw Gateway ───────────────────────────────────────────────────
echo ""
echo -e "${BOLD}3. OpenClaw Gateway${NC}"

PID=$(service_pid openclaw)
if [ -n "$PID" ]; then
  echo -e "  ${GREEN}✓${NC} Process already running (PID $PID)"
else
  echo -e "  ${YELLOW}→${NC} Starting OpenClaw gateway on port 18789..."
  nohup openclaw gateway run > "$LOGDIR/openclaw-gateway.log" 2>&1 &
  sleep 4
  PID=$(service_pid openclaw)
  if [ -n "$PID" ]; then
    echo -e "  ${GREEN}✓${NC} Started (PID $PID)"
  else
    echo -e "  ${RED}✗${NC} Failed to start OpenClaw gateway (check logs)"
  fi
fi

# Wait for it to listen
for i in $(seq 1 10); do
  is_listening 18789 && break
  sleep 1
done
if is_listening 18789; then
  echo -e "  ${GREEN}✓${NC} OpenClaw ready on port 18789"
else
  echo -e "  ${RED}✗${NC} OpenClaw not listening on port 18789"
fi

# ─── 4. Summary ────────────────────────────────────────────────────────────
echo ""
echo -e "${CYAN}────────────────────────────────────────${NC}"
echo ""

R9=$(is_listening 20128 && echo 1 || echo 0)
OC=$(is_listening 18789 && echo 1 || echo 0)

if [ "$R9" = 1 ] && [ "$OC" = 1 ]; then
  echo -e "${GREEN}${BOLD}✓ All services running!${NC}"
  echo ""
  echo -e "  ${BOLD}Control UI:${NC}  ${CYAN}http://127.0.0.1:18789${NC}"
  echo -e "  ${BOLD}9router:${NC}    ${CYAN}http://127.0.0.1:20128${NC}"
  echo ""
  # Try to get the public tunnel URL via proper auth
  TUNNEL_DATA=$(fetch_9r_api /api/tunnel/status 2>/dev/null || echo "")
  TUNNEL_URL=$(echo "$TUNNEL_DATA" | grep -o '"publicUrl":"[^"]*"' | cut -d'"' -f4 2>/dev/null)
  if [ -n "$TUNNEL_URL" ]; then
    echo -e "  ${BOLD}Tunnel:${NC}       ${CYAN}$TUNNEL_URL${NC}"
    echo ""
  fi
  echo -e "  ${YELLOW}Logs:${NC}"
  echo -e "    9router:  ${CYAN}tail -f $LOGDIR/9router.log${NC}"
  echo -e "    Gateway:  ${CYAN}tail -f $LOGDIR/openclaw-gateway.log${NC}"
elif [ "$R9" = 1 ]; then
  echo -e "${YELLOW}${BOLD}⚠  9router running but OpenClaw gateway not yet ready${NC}"
elif [ "$OC" = 1 ]; then
  echo -e "${YELLOW}${BOLD}⚠  OpenClaw gateway running but 9router not yet ready${NC}"
else
  echo -e "${RED}${BOLD}✗ Nothing started — check logs:${NC}"
  echo -e "  ${CYAN}tail -f $LOGDIR/9router.log${NC}"
  echo -e "  ${CYAN}tail -f $LOGDIR/openclaw-gateway.log${NC}"
fi
echo ""
